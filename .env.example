# Cortex Environment Variables
# Copy this file to .env and fill in your values

# LLM API Keys (optional — only needed for cloud LLM providers)
# CORTEX_LLM_DEFAULT_API_KEY=sk-your-api-key
# CORTEX_LLM_OPENAI_API_KEY=sk-your-openai-key
# CORTEX_LLM_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# LLM Configuration (overrides cortex.yaml)
# CORTEX_LLM_DEFAULT_PROVIDER=ollama
# CORTEX_LLM_DEFAULT_MODEL=codellama:7b
# CORTEX_LLM_DEFAULT_ENDPOINT=http://localhost:11434

# Server Configuration (overrides cortex.yaml)
# CORTEX_SERVER_PORT=8741
# CORTEX_SERVER_HOST=127.0.0.1
